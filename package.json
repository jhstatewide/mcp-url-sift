{
  "name": "mcp-url-sift",
  "version": "0.1.0",
  "description": "MCP server for budget-safe single URL content extraction.",
  "private": true,
  "type": "module",
  "bin": "bin/mcp-url-sift.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "mcp:dev": "tsx src/server.ts",
    "mcp:start": "node dist/server.js",
    "mcp:smoke": "npm run build && node dist/scripts/mcpSmokeTest.js"
  },
  "keywords": [
    "mcp",
    "url",
    "sift",
    "typescript"
  ],
  "author": "jhstatewide",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhstatewide/mcp-url-sift.git"
  },
  "bugs": {
    "url": "https://github.com/jhstatewide/mcp-url-sift/issues"
  },
  "homepage": "https://github.com/jhstatewide/mcp-url-sift#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "defuddle": "^0.17.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
